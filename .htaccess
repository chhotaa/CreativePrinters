# Block direct web access to version-control and CI metadata folders
# that Hostinger's Git deployment places inside public_html.
# These aren't meant to be served - .git exposes full repo history,
# .github is just workflow config with no runtime purpose on the site.
#
# Note: <DirectoryMatch> is NOT valid inside .htaccess (server/vhost
# context only) - using it here previously broke the entire site with
# a 500 error. mod_rewrite is the correct, .htaccess-safe approach.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/\.git(/|$) [OR]
    RewriteCond %{REQUEST_URI} ^/\.github(/|$)
    RewriteRule ^ - [F,L]
</IfModule>
